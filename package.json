{
  "name": "lamap-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "bun run --filter @lamap/mobile start",
    "mobile:ios": "bun run --filter @lamap/mobile ios",
    "mobile:android": "bun run --filter @lamap/mobile android",
    "convex:dev": "bun run --filter @lamap/convex dev",
    "convex:deploy": "bun run --filter @lamap/convex deploy",
    "web": "bun run --filter @lamap/web dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.9.2"
  }
}
