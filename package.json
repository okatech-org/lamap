{
  "name": "lamap-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "bun --filter @lamap/mobile run start",
    "mobile:ios": "bun --filter @lamap/mobile run ios",
    "mobile:android": "bun --filter @lamap/mobile run android",
    "convex:dev": "bun --filter @lamap/convex run dev",
    "convex:deploy": "bun --filter @lamap/convex run deploy",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "turbo": "^2.3.0",
    "typescript": "~5.9.2"
  }
}
