{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@assets/*": ["./assets/*"],
      "@lamap/convex": ["../../packages/convex/convex/_generated/api"],
      "@lamap/convex/_generated/*": ["../../packages/convex/convex/_generated/*"],
      "@lamap/convex/*": ["../../packages/convex/convex/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],
  "exclude": ["node_modules", "android", "ios", ".expo"]
}
