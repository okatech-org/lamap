# Convex deployment URL (same as mobile EXPO_PUBLIC_CONVEX_URL)
NEXT_PUBLIC_CONVEX_URL=

# Clerk — same instance as mobile (different key prefix)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Where Clerk should send users after sign-in / sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/auth/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/auth/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/play
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/play
